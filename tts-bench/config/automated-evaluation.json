{
  "schema_version": "1.0",
  "enabled_metrics": [
    "audio_health",
    "wavlm",
    "asr",
    "utmosv2"
  ],
  "audio_health": {
    "clipping_threshold": 0.999,
    "description": "仅检查可客观检测的削波与响度；不把静音或语速当作质量缺陷。"
  },
  "wavlm": {
    "model_id": "microsoft/wavlm-base-sv",
    "device": "cuda",
    "sample_rate_hz": 16000,
    "window_seconds": 5.0,
    "window_policy": "固定 5 秒；不足一窗的尾部从音频末尾反向取满，允许与前窗重叠。"
  },
  "asr": {
    "backend": "sensevoice",
    "model_id": "FunAudioLLM/SenseVoiceSmall",
    "device": "cuda",
    "language": "zh",
    "task": "transcribe",
    "description": "使用 hf-mirror 中的本地 SenseVoiceSmall，原始标签在 CER 规范化前移除。"
  },
  "utmosv2": {
    "checkpoint_id": "sarulab-speech/UTMOSv2/fold0_s42_best_model.pth"
  },
  "ranking": {
    "description": "configured_score 仅用于同一校准配置内的排序，不是人类主观 MOS，也不包含停顿、语气与情绪。本次沿用示例归一化区间，仅作同批相对比较。",
    "weights": {
      "asr_cer": 0.3,
      "speaker_similarity": 0.3,
      "utmosv2": 0.25,
      "speaker_stability": 0.1,
      "audio_health": 0.05
    },
    "normalizers": {
      "asr_cer": {"lower": 0.0, "upper": 0.2},
      "speaker_similarity": {"lower": 0.3, "upper": 0.9},
      "utmosv2": {"lower": 1.0, "upper": 5.0},
      "speaker_stability": {"lower": 0.3, "upper": 0.9},
      "audio_health": {"lower": 0.0, "upper": 0.01}
    }
  }
}
