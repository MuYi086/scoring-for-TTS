{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TTS Bench Case v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "split",
    "task",
    "language",
    "reference",
    "target",
    "evaluation_axes"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "case_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
    "split": {"enum": ["calibration", "development", "holdout"]},
    "task": {"enum": ["voice_cloning", "voice_design"]},
    "language": {"type": "string", "minLength": 2},
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["audio_path", "transcript"],
      "properties": {
        "audio_path": {"type": "string", "minLength": 1},
        "transcript": {"type": "string", "minLength": 1}
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": {"type": "string", "minLength": 1}
      }
    },
    "evaluation_axes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "timbre",
          "clarity",
          "pronunciation",
          "prosody",
          "consistency",
          "expression",
          "long_form"
        ]
      }
    }
  }
}
