{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TTS Bench Synthesis Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "case_id",
    "status",
    "model",
    "provenance"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
    "case_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
    "status": {"enum": ["complete", "failed", "excluded"]},
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1}
      }
    },
    "audio": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "sample_rate_hz", "channels", "duration_seconds"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "sample_rate_hz": {"type": "integer", "minimum": 1},
        "channels": {"type": "integer", "minimum": 1},
        "duration_seconds": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wall_seconds": {"type": "number", "minimum": 0},
        "device": {"type": "string"},
        "peak_memory_mb": {"type": "number", "minimum": 0}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inference_script", "config_sha256", "manifest_path"],
      "properties": {
        "inference_script": {"type": "string", "minLength": 1},
        "config_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "manifest_path": {"type": "string", "minLength": 1},
        "git_commit": {"type": "string"},
        "notes": {"type": "string"}
      }
    },
    "failure_reason": {"type": "string"}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "complete"}}},
      "then": {"required": ["audio", "runtime"]}
    },
    {
      "if": {"properties": {"status": {"enum": ["failed", "excluded"]}}},
      "then": {"required": ["failure_reason"]}
    }
  ]
}
