{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TTS Bench Metric Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "case_id",
    "evaluator",
    "evaluator_version",
    "source_audio_sha256",
    "result_path"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
    "case_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
    "evaluator": {"enum": ["wavlm", "asr", "tts-prism-7b", "listener-review"]},
    "evaluator_version": {"type": "string", "minLength": 1},
    "source_audio_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "result_path": {"type": "string", "minLength": 1},
    "preprocessing_id": {"type": "string"},
    "notes": {"type": "string"}
  }
}
