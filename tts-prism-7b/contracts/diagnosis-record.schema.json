{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TTS-PRISM-7B Diagnosis Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "case_id",
    "evaluator",
    "evaluator_version",
    "audio",
    "preprocessing_id",
    "basic_capability",
    "advanced_expressiveness",
    "raw_response_path"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
    "case_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
    "evaluator": {"const": "tts-prism-7b"},
    "evaluator_version": {"type": "string", "minLength": 1},
    "audio": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "preprocessing_id": {"type": "string", "minLength": 1},
    "basic_capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audio_clarity",
        "pronunciation",
        "intonation",
        "pauses",
        "speech_rate",
        "speaker_consistency",
        "style_consistency",
        "emotion_consistency"
      ],
      "properties": {
        "audio_clarity": {"type": "number", "minimum": 1, "maximum": 5},
        "pronunciation": {"type": "number", "minimum": 1, "maximum": 5},
        "intonation": {"type": "number", "minimum": 1, "maximum": 5},
        "pauses": {"type": "number", "minimum": 1, "maximum": 5},
        "speech_rate": {"type": "number", "minimum": 1, "maximum": 5},
        "speaker_consistency": {"type": "number", "minimum": 1, "maximum": 5},
        "style_consistency": {"type": "number", "minimum": 1, "maximum": 5},
        "emotion_consistency": {"type": "number", "minimum": 1, "maximum": 5}
      }
    },
    "advanced_expressiveness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stress", "lengthening", "paralinguistics", "emotion"],
      "properties": {
        "stress": {"type": "number", "minimum": 0, "maximum": 2},
        "lengthening": {"type": "number", "minimum": 0, "maximum": 2},
        "paralinguistics": {"type": "number", "minimum": 0, "maximum": 2},
        "emotion": {"type": "number", "minimum": 0, "maximum": 2}
      }
    },
    "rationale": {"type": "string"},
    "raw_response_path": {"type": "string", "minLength": 1}
  }
}
